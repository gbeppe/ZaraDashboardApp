<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Wrapping everything in a group to scale it down and fit the "Safe Zone" (66dp circle) -->
    <!-- pivotX/Y at 54,54 (center) and scale at 0.7 to ensure visibility on all launchers -->
    <group
        android:pivotX="54"
        android:pivotY="54"
        android:scaleX="0.65"
        android:scaleY="0.65">

        <!-- Smartphone Outline (Purple Neon) -->
        <path
            android:pathData="M35,20 H73 Q78,20 78,25 V83 Q78,88 73,88 H35 Q30,88 30,83 V25 Q30,20 35,20 Z"
            android:strokeColor="#E040FB"
            android:strokeWidth="2.5"
            android:fillColor="#00000000" />

        <!-- Top line of smartphone -->
        <path
            android:pathData="M30,30 H78"
            android:strokeColor="#E040FB"
            android:strokeWidth="2" />

        <!-- Bottom line of smartphone -->
        <path
            android:pathData="M30,78 H78"
            android:strokeColor="#E040FB"
            android:strokeWidth="2" />

        <!-- Bottom home indicator/button -->
        <path
            android:pathData="M50,83 H58"
            android:strokeColor="#4DD0E1"
            android:strokeWidth="3"
            android:strokeLineCap="round" />

        <!-- House Icon (Cyan Neon) -->
        <!-- Roof -->
        <path
            android:pathData="M54,38 L38,52 L42,52 V68 H66 V52 L70,52 Z"
            android:strokeColor="#4DD0E1"
            android:strokeWidth="3"
            android:fillColor="#00000000"
            android:strokeLineJoin="round" />

        <!-- House Body/Door (simplified) -->
        <path
            android:pathData="M48,68 V60 H60 V68"
            android:strokeColor="#4DD0E1"
            android:strokeWidth="2.5"
            android:fillColor="#00000000" />
    </group>

</vector>